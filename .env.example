# Database
DATABASE_URL=postgres://igift:yourpassword@localhost:5433/igift
POSTGRES_USER=igift
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=igift

# Public app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API Keys (generate strong random values for production)
ADMIN_API_KEY=change-me-to-a-random-64-char-hex-string
INGEST_API_KEY=change-me-to-a-random-64-char-hex-string

# Email (optional — for alert delivery)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=iGift Alerts <alerts@igift.app>

# Analytics / ads (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX   # GA4 Measurement ID
# GA4_API_SECRET=xxxxxxxxxxxx                  # GA4 > Data Streams > Measurement Protocol API secrets
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX

# Error monitoring (optional)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# LLM-assisted title/category normalization (optional)
# ANTHROPIC_API_KEY=sk-ant-...

# Affiliate deep-linking (optional)
# ADMITAD_BASE64_HEADER=Basic base64(client_id:client_secret)
# ADMITAD_CLIENT_ID=your-admitad-client-id

# Deploy (optional — for scripts/deploy.sh)
# DEPLOY_USER=igift
# DEPLOY_HOST=your.server.ip
# DEPLOY_PATH=/opt/igift
# DEPLOY_SSH_KEY=/path/to/your/ssh/key
